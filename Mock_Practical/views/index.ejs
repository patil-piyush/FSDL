<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Management System</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            padding: 20px;
        }

        h1 {
            text-align: center;
        }

        .container {
            max-width: 800px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
        }

        form {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        input {
            padding: 10px;
            flex: 1;
        }

        button {
            padding: 10px;
            background: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
            text-align: center;
        }

        th {
            background: #007bff;
            color: white;
        }
    </style>
</head>

<body>

<div class="container">
    <h1>Student Record System</h1>

    <!-- Form -->
    <form action="/students" method="POST">
        <input type="text" name="name" placeholder="Name" required>
        <input type="text" name="rollNo" placeholder="Roll No" required>
        <input type="text" name="branch" placeholder="Branch" required>
        <button type="submit">Add</button>
    </form>

    <!-- Table -->
    <table>
        <tr>
            <th>Name</th>
            <th>Roll No</th>
            <th>Branch</th>
        </tr>

        <% if (students.length > 0) { %>
            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.name %></td>
                    <td><%= student.rollNo %></td>
                    <td><%= student.branch %></td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="3">No records found</td>
            </tr>
        <% } %>
    </table>
</div>

</body>
</html>