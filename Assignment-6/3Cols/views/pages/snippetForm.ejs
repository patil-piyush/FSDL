<div class="page-content">
  <div class="container">

    <h1 class="section-title">Create Snippet</h1>

    <form action="<%= snippet ? `/snippet/edit/${snippet._id}` : '/snippet/new' %>" method="POST" class="auth-form">

      <!-- Title -->
      <div class="form-group">
        <label class="form-label" for="title">Title</label>
        <input type="text" id="title" name="title" class="form-input" placeholder="Enter snippet title"
          value="<%= snippet ? snippet.title : '' %>" required>
      </div>

      <!-- Language -->
      <div class="form-group">
        <label class="form-label" for="lang-select">Language</label>

        <select name="lang" id="lang-select" class="form-input" required>
          <option value="">Select Language</option>

          <% const
            langs=['javascript','python','java','c','cpp','csharp','go','rust','kotlin','swift','typescript','php','ruby','sql','bash'];
            %>

            <% langs.forEach(l=> { %>
              <option value="<%= l %>" <%=snippet && snippet.lang===l ? 'selected' : '' %>>
                <%= l.toUpperCase() %>
              </option>
              <% }) %>
        </select>
      </div>

      <!-- Code -->
      <div class="form-group">
        <label class="form-label" for="code">Code</label>
        <textarea id="code" name="code" rows="10" class="form-input"
          required><%= snippet ? snippet.code : '' %></textarea>
      </div>

      <!-- Tags -->
      <div class="form-group">
        <label class="form-label" for="tags">Tags (comma separated)</label>
        <input type="text" id="tags" name="tags" class="form-input"
          value="<%= snippet ? snippet.tags.join(', ') : '' %>">
      </div>

      <!-- Submit -->
      <button type="submit" class="btn btn-primary btn-lg w-full">
        <i class="fa-solid <%= snippet ? 'fa-pen' : 'fa-plus' %>"></i>
        <%= snippet ? 'Update Snippet' : 'Save Snippet' %>
      </button>

    </form>

  </div>
</div>